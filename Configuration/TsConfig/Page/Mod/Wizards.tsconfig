mod.wizards.newContentElement.wizardItems.media {
  elements {
    photoswipe {
      iconIdentifier = content-photoswipe
      title = LLL:EXT:photoswipe/Resources/Private/Language/locallang_db.xlf:plugin.title
      description = PhotoSwipe Galerie (with user selection of images)
      tt_content_defValues.CType = photoswipe
    }
  }
  show := addToList(photoswipe)
}
