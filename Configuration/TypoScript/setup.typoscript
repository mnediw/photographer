tt_content.photographer =< lib.contentElement
tt_content.photographer {
  templateName = Photographer
  templateRootPaths.10 = EXT:photographer/Resources/Private/Templates/Content/
  partialRootPaths.10 = EXT:photographer/Resources/Private/Partials/
  layoutRootPaths.10 = EXT:photosgrapher/Resources/Private/Layouts/

  dataProcessing {
    10 = Diw\Photographer\DataProcessing\PhotographerProcessor
  }
}

# Note: CSS/JS are enqueued from the Fluid template via <f:asset.*>.
